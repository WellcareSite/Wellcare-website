<!-- Footer Logo Banner (white background) -->
<div class="footer-logo-banner">
  <div class="container" style="text-align: center; padding: 2rem 1rem 4.5rem;">
    <a href="/">
      <img src="/images/logo.png" alt="WellCare & Nurture" width="420" style="border-radius: 12px;">
    </a>
  </div>
</div>

<!-- Wave transition to footer -->
<div class="wave-divider" style="margin-top: -60px; position: relative; z-index: 2;">
  <svg viewBox="0 0 1200 80" preserveAspectRatio="none" style="height:80px;">
    <path d="M0,60 C200,20 400,20 600,40 C800,60 1000,60 1200,20 L1200,80 L0,80 Z" fill="#c5e8f5"/>
  </svg>
</div>

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid" style="grid-template-columns: 1fr 1fr; max-width: 800px; margin: 0 auto;">
      <!-- Column 1: Quick Links -->
      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul class="footer-links">
          <li><a href="/aba/">→ ABA Therapy</a></li>
          <li><a href="/occupational-therapy/">→ Occupational Therapy</a></li>
          <li><a href="/physical-therapy/">→ Physical Therapy</a></li>
          <li><a href="/speech-therapy/">→ Speech Therapy</a></li>
          <li><a href="/team/">→ Our Team</a></li>
          <li><a href="/contact/">→ Contact Us</a></li>
        </ul>
      </div>

      <!-- Column 2: Contact & Newsletter -->
      <div class="footer-col">
        <h4>Join Our Community!</h4>
        <p>Sign up for parenting tips, program offers, events and more!</p>
        <form class="newsletter-form" id="newsletter-form">
          <input type="email" placeholder="Email Address" required aria-label="Email Address">
          <button type="submit">Subscribe</button>
        </form>

        <h4 style="margin-top: 1.5rem;">Contact</h4>
        <p>
          📞 <a href="tel:{{ settings.phone | replace('(', '') | replace(')', '') | replace(' ', '') | replace('-', '') }}">{{ settings.phone }}</a><br>
          ✉ <a href="mailto:{{ settings.email }}">{{ settings.email }}</a><br>
          💬 <a href="#" class="footer-text-us" onclick="document.querySelector('.weave-text-connect-button')?.click(); return false;">Text Us</a>
        </p>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <div class="footer-social">
        <a href="mailto:{{ settings.email }}" aria-label="Email">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </a>
        <a href="{{ settings.social.facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
        </a>
        <a href="{{ settings.social.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 01-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 017.8 2zm-.2 2A3.6 3.6 0 004 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 003.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6zm9.65 1.5a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM12 7a5 5 0 110 10 5 5 0 010-10zm0 2a3 3 0 100 6 3 3 0 000-6z"/></svg>
        </a>
        <a href="{{ settings.social.linkedin }}" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M19 3a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14m-.5 15.5v-5.3a3.26 3.26 0 00-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 011.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 001.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 00-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
        </a>
      </div>
      <p>&copy; 2026 {{ settings.siteName }}. All rights reserved. | <a href="/privacy/">Privacy Policy</a></p>
    </div>
  </div>
</footer>
