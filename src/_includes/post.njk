---
layout: base.njk
title: Blog Post
---

<section class="page-hero">
  <div class="container">
    <h1>{{ title }}</h1>
    <p>{{ date | date("MMMM d, yyyy") if date else "" }}{% if author %} • {{ author }}{% endif %}</p>
  </div>
</section>

<!-- Wave: Hero → Content -->
<div class="wave-divider" style="margin-top: -60px; position: relative; z-index: 2;">
  <svg viewBox="0 0 1200 80" preserveAspectRatio="none" style="height:80px;">
    <path d="M0,60 C200,20 400,20 600,40 C800,60 1000,60 1200,20 L1200,80 L0,80 Z" fill="white"/>
  </svg>
</div>

<section class="content-page">
  <div class="container">
    {# Auto-image system: use explicit image if provided, otherwise rotate through a pool based on tags #}
    {# Uses title length as a simple hash to vary the image selection per post #}
    {% set titleHash = title | length %}
    {% if image %}
      {% set blogImage = image %}
    {% elif "aba" in tags %}
      {% set abaImages = ["/images/blog-aba-therapy-diverse.png", "/images/blog-aba-therapy.png", "/images/blog-reinforcement.png"] %}
      {% set blogImage = abaImages[titleHash % 3] %}
    {% elif "speech therapy" in tags %}
      {% set speechImages = ["/images/blog-late-talker-diverse.png", "/images/blog-late-talker.png", "/images/blog-vocabulary.png", "/images/blog-play-language.png"] %}
      {% set blogImage = speechImages[titleHash % 4] %}
    {% elif "occupational therapy" in tags %}
      {% set otImages = ["/images/blog-sensory-diverse.png", "/images/blog-sensory.png", "/images/blog-fine-motor.png", "/images/blog-picky-eating-diverse.png"] %}
      {% set blogImage = otImages[titleHash % 4] %}
    {% elif "physical therapy" in tags %}
      {% set ptImages = ["/images/blog-gross-motor-diverse.png", "/images/blog-gross-motor.png", "/images/blog-tummy-time.png", "/images/blog-toe-walking-diverse.png"] %}
      {% set blogImage = ptImages[titleHash % 4] %}
    {% elif "sensory" in tags %}
      {% set sensoryImages = ["/images/blog-sensory-diverse.png", "/images/blog-sensory.png", "/images/blog-picky-eating-diverse.png"] %}
      {% set blogImage = sensoryImages[titleHash % 3] %}
    {% elif "milestones" in tags %}
      {% set milestoneImages = ["/images/blog-tummy-time.png", "/images/blog-gross-motor-diverse.png", "/images/blog-transitions.png"] %}
      {% set blogImage = milestoneImages[titleHash % 3] %}
    {% elif "feeding" in tags %}
      {% set feedingImages = ["/images/blog-picky-eating-diverse.png", "/images/blog-picky-eating.png"] %}
      {% set blogImage = feedingImages[titleHash % 2] %}
    {% else %}
      {% set defaultImages = ["/images/blog-play-language.png", "/images/blog-transitions.png", "/images/blog-aac-device.png", "/images/blog-vocabulary.png"] %}
      {% set blogImage = defaultImages[titleHash % 4] %}
    {% endif %}
    <img src="{{ blogImage }}" alt="{{ title }}" style="border-radius: 12px; margin-bottom: 2rem; width: 100%; max-height: 400px; object-fit: cover;">
    {{ content | safe }}
    
    <!-- Global Blog CTA -->
    <div class="blog-cta" style="margin-top: 3rem; padding: 2rem; background: linear-gradient(135deg, #e8f4fa 0%, #d0ebf7 100%); border-radius: 12px; border-left: 4px solid var(--sky-blue); text-align: left;">
      <h3 style="color: var(--dark-blue); margin-bottom: 1rem; font-size: 1.5rem;">Is your child showing signs of needing support?</h3>
      <p style="color: #444; font-size: 1rem; line-height: 1.6; margin-bottom: 1.5rem;">If the topics in this post sound like your child, our team of pediatric specialists is here to help. We provide personalized ABA, Occupational, Physical, and Speech Therapy in Colorado Springs.</p>
      <a href="/contact/" class="btn-primary" style="display: inline-block; padding: 0.8rem 1.5rem; background-color: var(--sky-blue); color: white; text-decoration: none; border-radius: 8px; font-weight: bold; transition: background-color 0.3s ease;">Schedule a Free Screening</a>
    </div>
  </div>
</section>
