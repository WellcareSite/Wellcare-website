---
layout: base.njk
title: Blog Post
---

<section class="page-hero">
  <div class="container">
    <h1>{{ title }}</h1>
    <p>{{ date | date("MMMM d, yyyy") if date else "" }}{% if author %} • {{ author }}{% endif %}</p>
  </div>
</section>

<!-- Wave: Hero → Content -->
<div class="wave-divider" style="margin-top: -60px; position: relative; z-index: 2;">
  <svg viewBox="0 0 1200 80" preserveAspectRatio="none" style="height:80px;">
    <path d="M0,60 C200,20 400,20 600,40 C800,60 1000,60 1200,20 L1200,80 L0,80 Z" fill="white"/>
  </svg>
</div>

<section class="content-page">
  <div class="container">
    {% if image %}
    <img src="{{ image }}" alt="{{ title }}" style="border-radius: 12px; margin-bottom: 2rem; width: 100%; max-height: 400px; object-fit: cover;">
    {% endif %}
    {{ content | safe }}
  </div>
</section>
