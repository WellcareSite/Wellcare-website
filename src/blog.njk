---
layout: base.njk
title: Blog
description: Read the latest articles and insights from WellCare & Nurture Pediatric Therapy.
permalink: /blog/
---

<section class="page-hero">
  <div class="container">
    <h1>Our Blog</h1>
    <p>Insights, tips, and stories from our team</p>
  </div>
  <svg class="hero-bottom-wave" viewBox="0 0 1440 80" preserveAspectRatio="none">
    <path d="M0,48 C240,80 480,0 720,40 C960,80 1200,10 1440,48 L1440,80 L0,80 Z" fill="white"/>
  </svg>
</section>

<section class="section">
  <div class="container">
    {% if collections.posts.length %}
    <div class="blog-grid">
      {% for post in collections.posts %}
      <article class="blog-card">
        <div class="blog-card-img" style="background-image: url('{{ post.data.image or '/images/blog-placeholder.jpg' }}');"></div>
        <div class="blog-card-body">
          <div class="date">{{ post.date | date("MMMM d, yyyy") if post.date else "" }}</div>
          <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
          <p class="excerpt">{{ post.data.excerpt or post.templateContent | truncate(150) }}</p>
          <a href="{{ post.url }}" class="btn-learn-more">Read More →</a>
        </div>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <div style="text-align: center; padding: 3rem;">
      <h2>Coming Soon!</h2>
      <p>We're working on exciting new content. Check back soon for articles, tips, and stories from our team.</p>
    </div>
    {% endif %}
  </div>
</section>
