---
layout: base.njk
title: "Contact Us — Free Screenings in Colorado Springs"
description: "Contact WellCare & Nurture Pediatric Therapy in Colorado Springs. Schedule a free screening, request information about ABA, OT, PT or speech therapy. Call (719) 598-5555. Two convenient locations."
permalink: /contact/
---

<section class="page-hero">
  <div class="container">
    <h1>Contact Us</h1>
    <p>We'd love to hear from you. Reach out today!</p>
  </div>
  <svg class="hero-bottom-wave" viewBox="0 0 1440 80" preserveAspectRatio="none">
    <path d="M0,48 C240,80 480,0 720,40 C960,80 1200,10 1440,48 L1440,80 L0,80 Z" fill="white"/>
  </svg>
</section>

<section class="section">
  <div class="container" style="max-width: 900px;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;">
      <!-- Contact Info -->
      <div>
        <h2>Get In Touch</h2>
        <p style="margin-bottom: 2rem;">Whether you have questions about our services, want to schedule a consultation, or need more information, we're here to help.</p>

        <div style="margin-bottom: 1.5rem;">
          <h3>📞 Phone</h3>
          <p><a href="tel:{{ settings.phone | replace('(', '') | replace(')', '') | replace(' ', '') | replace('-', '') }}">{{ settings.phone }}</a></p>
        </div>

        <div style="margin-bottom: 1.5rem;">
          <h3>✉ Email</h3>
          <p><a href="mailto:{{ settings.email }}">{{ settings.email }}</a></p>
        </div>

        <h3 style="margin-top: 2rem;">📍 Locations</h3>
        {% for loc in settings.locations %}
        <div style="margin-bottom: 1rem; padding: 1rem; background: var(--bg-lighter); border-radius: 8px;">
          <strong>{{ loc.name }}</strong><br>
          {{ loc.address }}<br>
          {{ loc.city }}, {{ loc.state }} {{ loc.zip }}<br>
          <a href="{{ loc.mapUrl }}" target="_blank" rel="noopener">🗺️ Get Directions</a>
        </div>
        {% endfor %}
      </div>

      <!-- Contact Form -->
      <div>
        <h2>Send Us a Message</h2>
        <form class="contact-form" name="contact" method="POST" data-netlify="true" id="contact-form">
          <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone">
          </div>
          <div class="form-group">
            <label for="service">Service of Interest</label>
            <select id="service" name="service">
              <option value="">Select a service...</option>
              <option value="aba">Applied Behavior Analysis (ABA)</option>
              <option value="ot">Occupational Therapy</option>
              <option value="pt">Physical Therapy</option>
              <option value="speech">Speech-Language Pathology</option>
              <option value="other">Other / General Inquiry</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required></textarea>
          </div>
          <button type="submit" class="btn-submit">Send Message ✉</button>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- Google Map Embed -->
<section class="section section-light" id="map-section">
  <div class="container" style="max-width: 900px;">
    <h2 style="text-align: center; margin-bottom: 1.5rem;">Find Us in Colorado Springs</h2>
    <p style="text-align: center; margin-bottom: 2rem; color: var(--text-muted);">Serving families across Colorado Springs and the Pikes Peak region</p>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
      <div>
        <h3 style="margin-bottom: 0.5rem;">📍 Frequent Flyer Point</h3>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.75rem;">1930 Frequent Flyer Point, Colorado Springs, CO 80915</p>
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3107.5!2d-104.7365!3d38.8585!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s1930+Frequent+Flyer+Point+Colorado+Springs+CO+80915!5e0!3m2!1sen!2sus" width="100%" height="250" style="border:0; border-radius: 12px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="WellCare Frequent Flyer Point location map"></iframe>
      </div>
      <div>
        <h3 style="margin-bottom: 0.5rem;">📍 Academy Circle</h3>
        <p style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.75rem;">2105 Academy Circle, Colorado Springs, CO 80909</p>
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3107.5!2d-104.7875!3d38.8485!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s2105+Academy+Circle+Colorado+Springs+CO+80909!5e0!3m2!1sen!2sus" width="100%" height="250" style="border:0; border-radius: 12px;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="WellCare Academy Circle location map"></iframe>
      </div>
    </div>
  </div>
</section>
