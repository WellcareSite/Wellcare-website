<section class="section" id="locations-section" style="padding-top: 1.5rem;">
  <div class="container">
    <div class="section-header">
      <h2>Come Visit Today!</h2>
      <p>Two convenient locations in Colorado Springs</p>
    </div>
    <div class="locations-grid">
      {% for loc in settings.locations %}
      <div class="location-card">
        <h3>📍 {{ loc.name }}</h3>
        <div class="address">{{ loc.address }}, {{ loc.city }}, {{ loc.state }} {{ loc.zip }}</div>
        <div class="phone">📞 <a href="tel:{{ loc.phone | replace('(', '') | replace(')', '') | replace(' ', '') | replace('-', '') }}">{{ loc.phone }}</a></div>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.75rem;">
          <a href="{{ loc.mapUrl }}" target="_blank" rel="noopener" class="btn-directions">🗺️ Get Directions →</a>
          {% if loc.reviewUrl %}
            <a href="{{ loc.reviewUrl }}" target="_blank" rel="noopener" class="btn-directions" style="background: #f5a623; color: white;">⭐ Leave a Review</a>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

