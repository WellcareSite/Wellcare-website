        <div style="width: 96px; height: 96px; margin: 0 auto 1rem; background: linear-gradient(135deg, #e8f4fa 0%, #d0ebf7 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; border: 3px solid var(--sky-blue); box-shadow: 0 4px 15px rgba(94,182,217,0.2);">📋</div>
