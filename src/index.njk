<!-- Insurance & Partners Section -->
<section class="section section-light" id="insurance-section" style="padding-top: 1.5rem;">
  <div class="container">
    <div class="section-header" style="margin-bottom: 1rem;">
      <h2>Insurance</h2>
    </div>
    <div class="partners-grid">
      {% for partner in insurance.items %}
        <div class="partner-badge">
          {% if partner.logo %}
            <img src="{{ partner.logo }}" alt="{{ partner.name }}" class="partner-logo" {% if partner.name == "Aetna" %}style="height: 70px; width: 160px;"{% elif partner.name == "BlueCross BlueShield" %}style="height: 120px; width: 220px;"{% endif %}>
          {% else %}
            {{ partner.name }}
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <h3 style="text-align: center; margin-top: 2.5rem; margin-bottom: 1.5rem; color: var(--dark-blue);">Community Partners</h3>
    <div class="partners-grid" style="justify-content: center;">
      {% for partner in communityPartners.items %}
        <div class="partner-badge" style="min-width: 200px; max-width: 200px;">
          {% if partner.logo %}
            <img src="{{ partner.logo }}" alt="{{ partner.name }}" class="partner-logo" style="height: 80px;">
          {% else %}
            {{ partner.name }}
          {% endif %}
        </div>
      {% endfor %}
