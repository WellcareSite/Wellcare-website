---
layout: base.njk
title: "{{ serviceOt.heroTitle }}"
description: "{{ serviceOt.seoDescription }}"
permalink: /occupational-therapy/
---

{# ── Hero: Unified gradient + masked photo + bottom wave ── #}
<section class="service-hero service-hero--ot">
  <div class="service-hero-photo" style="background-image: url('{{ serviceOt.heroImage }}');"></div>
  <div class="service-hero-content">
    <div class="container">
      <div class="service-hero-text">
        <h1>{{ serviceOt.heroTitle }}</h1>
        <p>{{ serviceOt.heroSubtitle }}</p>
        <div class="hero-actions">
          <a href="{{ settings.screeningUrl }}" class="hero-btn-screening">📋 Schedule a Free Screening</a>
          <a href="/milestone-check/" class="hero-btn-milestone">🌱 Try Our Milestone Tool</a>
        </div>
      </div>
    </div>
  </div>
  <svg class="hero-bottom-wave" viewBox="0 0 1440 80" preserveAspectRatio="none">
    <path d="M0,48 C240,80 480,0 720,40 C960,80 1200,10 1440,48 L1440,80 L0,80 Z" fill="white"/>
  </svg>
</section>

{# ── Intro + What We Help With ── #}
<section class="section sp-intro">
  <div class="container">
    <div class="sp-intro-grid">
      <div class="sp-intro-text">
        {{ serviceOt.intro | markdownify | safe }}
      </div>
      <div class="sp-services-card">
        <h2>What We Help With</h2>
        <ul class="sp-services-list">
          {% for item in serviceOt.services %}
          <li>
            <span class="sp-check">✓</span>
            {{ item }}
          </li>
          {% endfor %}
        </ul>
        <p class="sp-service-note">{{ serviceOt.serviceNote | markdownify | safe }}</p>
      </div>
    </div>
  </div>
</section>

{# ── Our Specialties (Expandable) ── #}
<section class="section sp-specialties">
  <div class="container">
    <div class="sp-specialties-layout">
      <div class="sp-specialties-text">
        <h2>Our Specialties</h2>
        <p>Tap any specialty below to learn how we can help your child.</p>
        {% for item in serviceOt.learnMore %}
        <details class="learn-more-item">
          <summary><span class="lm-icon">{{ item.icon }}</span> {{ item.title }}</summary>
          <div class="learn-more-content">
            {{ item.content | markdownify | safe }}
          </div>
        </details>
        {% endfor %}
      </div>
      <div class="sp-specialties-img" style="background-image: url('{{ serviceOt.image }}');"></div>
    </div>
  </div>
</section>

{# ── Glass Card CTA ── #}
<section class="section sp-cta-section">
  <div class="container">
    <div class="service-glass-card service-glass-card-centered">
      <p class="service-glass-heading">Not sure if your child could benefit from occupational therapy?</p>
      <p class="service-glass-subtext">We're here to help — no pressure, no cost</p>
      <div class="service-glass-buttons">
        <a href="{{ settings.screeningUrl }}" class="hero-btn-screening">📋 Schedule a Free Screening</a>
        <a href="/milestone-check/" class="hero-btn-milestone">🌱 Try Our Milestone Tool</a>
      </div>
    </div>
  </div>
</section>

{# ── FAQs ── #}
{% if serviceOt.faqs.length > 0 %}
<section class="section sp-faq-section">
  <div class="container">
    <div class="section-header">
      <h2>Common Questions</h2>
    </div>
    <div class="faq-section">
      {% for faq in serviceOt.faqs %}
      <details class="faq-item">
        <summary>{{ faq.question }}</summary>
        <div class="faq-answer">
          {{ faq.answer | markdownify | safe }}
        </div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ── Insurance ── #}
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>Insurance Partners</h2>
    </div>
    <div class="partners-grid">
      {% for partner in insurance.items %}
        <div class="partner-badge">
          {% if partner.logo %}
            <img src="{{ partner.logo }}" alt="{{ partner.name }}" class="partner-logo">
          {% else %}
            {{ partner.name }}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>
