---
layout: base.njk
title: "{{ servicePt.heroTitle }}"
description: "{{ servicePt.seoDescription }}"
permalink: /physical-therapy/
---

<section class="page-hero">
  <div class="container">
    <h1>{{ servicePt.heroTitle }}</h1>
    <p>{{ servicePt.heroSubtitle }}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="service-detail reverse">
      <div>
        <h2>Our Approach</h2>
        {{ servicePt.content | markdownify | safe }}
        <a href="/team/" class="btn-cta" style="margin-top: 1.5rem;">Meet Our Therapists</a>
        <a href="{{ settings.screeningUrl }}" class="btn-cta" style="margin-top: 0.5rem; background: var(--dark-blue);">📋 Schedule Your Free Screening</a>
      </div>
      <div class="service-detail-img" style="background-image: url('{{ servicePt.image }}');"></div>
    </div>
  </div>
</section>

{% if servicePt.faqs.length > 0 %}
<section class="section section-light">
  <div class="container">
    <div class="section-header">
      <h2>Frequently Asked Questions</h2>
    </div>
    <div class="faq-section">
      {% for faq in servicePt.faqs %}
      <details class="faq-item">
        <summary>{{ faq.question }}</summary>
        <div class="faq-answer">
          <p>{{ faq.answer }}</p>
        </div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Insurance Section -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>Insurance Partners</h2>
    </div>
    <div class="partners-grid">
      {% for partner in insurance %}
        <div class="partner-badge">
          {% if partner.logo %}
            <img src="{{ partner.logo }}" alt="{{ partner.name }}" class="partner-logo">
          {% else %}
            {{ partner.name }}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>
